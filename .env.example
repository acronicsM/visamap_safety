# База API без пути /countries/names (к нему добавляется /countries/names)
API_COUNTRIES_URL=http://127.0.0.1:8000

# PDF для Gallup и WPS (пайплайн run_safety_pipeline.py)
GALLUP_DATA_FILE=input_data\Gallup_Global-Safety-Report-2025.pdf
WOMEN_PEACE_SECURITY_INDEX_FILE=input_data\Women_Peace_Security_Index_2025.pdf

# Опционально: куда сохранить кэш справочника при fetch (по умолчанию reference_countries.json в корне)
# REFERENCE_COUNTRIES_FILE=reference_countries.json

# Опционально: итог объединения (по умолчанию safety_merged.json)
# MERGED_OUTPUT_FILE=safety_merged.json

# Единый индекс безопасности (веса, границы GPI / Gallup L&O) и ручные поправки по iso2
# SAFETY_INDEX_CONFIG_FILE=safety_index_config.json
# SAFETY_MANUAL_SCORES_FILE=safety_manual_scores.json

# Опционально: ручные алиасы и iso2 -> отображаемое имя (по умолчанию manual_country_map.json рядом со скриптами)
# MANUAL_COUNTRY_MAP_FILE=manual_country_map.json

# После merge: удалять промежуточные *_data.json и reference в корне репо (1) или оставить (0). Перекрывается флагом --keep-intermediate
# SAFETY_PIPELINE_DELETE_INTERMEDIATE=1
