# Для одиночных парсеров: база API без пути /countries/names (к нему добавляется /countries/names при отсутствии --reference-json)
API_COUNTRIES_URL=http://127.0.0.1:8000

# GPIparser / Wikipedia: своя строка User-Agent с контактом (URL репозитория или email). Иначе возможны 403 / rate limit.
# https://meta.wikimedia.org/wiki/User-Agent_policy
# WIKIPEDIA_USER_AGENT=MyProject/1.0 (https://example.org/your-repo; you@example.com) python-requests/2.32

# PDF для Gallup и WPS (пайплайн run_safety_pipeline.py)
GALLUP_DATA_FILE=input_data\Gallup_Global-Safety-Report-2025.pdf
WOMEN_PEACE_SECURITY_INDEX_FILE=input_data\Women_Peace_Security_Index_2025.pdf

# Обязательно для run_safety_pipeline.py: локальный JSON справочника стран (по умолчанию reference_countries.json в корне)
REFERENCE_COUNTRIES_FILE=reference_countries.json

# Итог объединения (по умолчанию safety_merged.json)
# MERGED_OUTPUT_FILE=safety_merged.json

# Полный URL GET справочника: sync_safety_reference.py --download-reference-only или шаг GET после PUT
# REFERENCE_COUNTRIES_DOWNLOAD_URL=http://127.0.0.1:8000/countries/names

# PUT баллов и обновление справочника: sync_safety_reference.py (by_iso2 → safety_final_score)
# Полный URL админского эндпоинта
# SAFETY_FINAL_SCORES_PUT_URL=https://api.example.com/admin/countries/safety-final-scores
# Заголовок X-Api-Key
# SAFETY_FINAL_SCORES_X_API_KEY=

# Единый индекс безопасности (веса, границы GPI / Gallup L&O) и ручные поправки по iso2
# SAFETY_INDEX_CONFIG_FILE=safety_index_config.json
# SAFETY_MANUAL_SCORES_FILE=safety_manual_scores.json

# Опционально: ручные алиасы и iso2 -> отображаемое имя (по умолчанию manual_country_map.json рядом со скриптами)
# MANUAL_COUNTRY_MAP_FILE=manual_country_map.json

# Файл отчёта analyze_safety_merged.py (по умолчанию safety_merged_analysis.txt рядом с MERGED_OUTPUT_FILE)
# SAFETY_MERGED_ANALYSIS_OUT=safety_merged_analysis.txt

# Порог для analyze_safety_merged.py: доля шкалы 0–100 (0.1 = 10 пунктов размаха max−min по safety_norm_*)
# SAFETY_NORM_SPREAD_THRESHOLD_PCT=0.1

# Разброс в analyze_safety_merged.py: minmax | mean | median (см. SAFETY_NORM_SPREAD_MODE в analyze_safety_merged.py)
# SAFETY_NORM_SPREAD_MODE=minmax

# sync_safety_reference.py: что подставлять в safety_final_score при PUT: final | composite | median
# SAFETY_PUT_SCORE_SOURCE=final

